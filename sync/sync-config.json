{
  "version": "1.0.0",
  "enabled": false,
  "provider": null,
  "config": {
    "git": {
      "enabled": false,
      "remote": "YOUR_GIT_REPO_URL_HERE",
      "branch": "main",
      "autoCommit": true,
      "commitMessage": "💪 auto-sync: {{timestamp}}"
    },
    "webdav": {
      "enabled": false,
      "url": null,
      "username": null,
      "passwordEnv": "WEBDAV_PASSWORD"
    },
    "s3": {
      "enabled": false,
      "bucket": null,
      "region": null,
      "accessKeyIdEnv": "AWS_ACCESS_KEY_ID",
      "secretAccessKeyEnv": "AWS_SECRET_ACCESS_KEY"
    },
    "dropbox": {
      "enabled": false,
      "tokenEnv": "DROPBOX_TOKEN",
      "path": "/openclaw/entj-muscle-coach"
    },
    "gdrive": {
      "enabled": false,
      "credentialsEnv": "GDRIVE_CREDENTIALS",
      "folderId": null
    }
  },
  "syncRules": {
    "include": [
      "state/*.json",
      "state/*.md",
      "cron/*.json",
      "config/*.json",
      "bioclock/*.json"
    ],
    "exclude": [
      "*.log",
      "*.tmp",
      ".git/*"
    ]
  },
  "conflictResolution": {
    "strategy": "newest",
    "backupBeforeOverwrite": true,
    "notifyOnConflict": true
  },
  "schedule": {
    "autoSync": false,
    "intervalMs": 300000,
    "syncOnWrite": true
  },
  "lastSync": null,
  "syncHistory": [],
  "_comment": "TEMPLATE: 請在 Private 倉庫中配置您的同步設置"
}
